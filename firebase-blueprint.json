{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Firebase Auth UID"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "displayName": {
          "type": "string"
        },
        "photoURL": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "A workspace or project containing documents",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "ownerId": {
          "type": "string",
          "description": "UID of the user who owns the project"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "path": {
          "type": "string",
          "description": "Local path to the Obsidian vault"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["ownerId", "name", "createdAt", "updatedAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat session containing messages",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string",
          "description": "UID of the user who owns the chat"
        },
        "title": {
          "type": "string"
        },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": {
                "type": "string",
                "enum": ["user", "assistant", "system"]
              },
              "content": {
                "type": "string"
              },
              "model": {
                "type": "string"
              }
            },
            "required": ["role", "content"]
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId", "title", "messages", "createdAt", "updatedAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "User specific settings synchronized across devices",
      "type": "object",
      "properties": {
        "ownerId": {
          "type": "string"
        },
        "theme": {
          "type": "string",
          "enum": ["dark", "light", "system"]
        },
        "language": {
          "type": "string",
          "enum": ["it", "en"]
        },
        "routerQualityPreference": {
          "type": "number"
        },
        "semanticCacheEnabled": {
          "type": "boolean"
        },
        "cacheSimilarityThreshold": {
          "type": "number"
        },
        "masterModel": {
          "type": "string"
        },
        "fallbackModel": {
          "type": "string"
        },
        "openAiApiKey": {
          "type": "string"
        },
        "anthropicApiKey": {
          "type": "string"
        },
        "groqApiKey": {
          "type": "string"
        },
        "deepseekApiKey": {
          "type": "string"
        },
        "ollamaUrl": {
          "type": "string"
        },
        "colabEndpoint": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["ownerId", "updatedAt"]
    },
    "SemanticCache": {
      "title": "SemanticCache",
      "description": "Cached responses for semantic similarity matching",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string",
          "description": "UID of the user who owns the cache entry"
        },
        "query": {
          "type": "string"
        },
        "response": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId", "query", "response", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "User profiles"
    },
    "projects/{projectId}": {
      "schema": {
        "$ref": "#/entities/Project"
      },
      "description": "User projects/workspaces"
    },
    "settings/{userId}": {
      "schema": {
        "$ref": "#/entities/Settings"
      },
      "description": "User synchronized settings"
    },
    "chats/{chatId}": {
      "schema": {
        "$ref": "#/entities/Chat"
      },
      "description": "User chat sessions"
    },
    "caches/{cacheId}": {
      "schema": {
        "$ref": "#/entities/SemanticCache"
      },
      "description": "User semantic cache entries"
    }
  }
}
